# Общие
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-long-random-string

# JWT (auth-service; для gateway при проверке токенов позже — тот же секрет)
JWT_SECRET_KEY=change-me-in-production-use-long-random-string

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=app_secret
POSTGRES_DB=ai_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# rag-service: сохранять чанки RAG в PostgreSQL (после рестарта индекс восстанавливается). Без БД: RAG_ENABLE_DB=false
RAG_ENABLE_DB=true
# Чанкинг: langchain (LangChain RecursiveCharacterTextSplitter), llama_index (LlamaIndex SentenceSplitter), legacy (старое окно)
# RAG_CHUNKER=langchain
# --- RAG: эмбеддер (векторизация) — см. брифинг кейсодержателя ---
# API: OpenAI-совместимый POST {BASE}/v1/embeddings. Пустой EMBEDDER_BASE_URL — только TF-IDF в rag-service.
#
# Чаще всего на хакатоне эмбеддер даёт организатор: полный URL и имя модели — из их инструкции / чата.
# Пример (замените на выданные значения; LLM часто на другом порту, эмбеддер — свой, напр. 6620):
# EMBEDDER_BASE_URL=https://hackai.centrinvest.ru:6620
# EMBEDDER_MODEL=<как в GET /v1/models на сервере эмбеддера>
# Из Docker контейнер ходит в интернет как обычно — внешний URL организаторов указывайте как есть (https://...).
#
# Отдельный случай: эмбеддер только на вашем ПК, стек в Docker (не localhost):
# EMBEDDER_BASE_URL=http://host.docker.internal:6620
#
# Без эмбеддера (TF-IDF) — не задавайте URL или оставьте пустым:
# EMBEDDER_BASE_URL=
# EMBEDDER_MODEL=
# EMBEDDER_BATCH_SIZE=32
# EMBEDDER_TIMEOUT_SECONDS=120

# URL auth-service для api-gateway (в Docker: http://auth-service:8001)
AUTH_SERVICE_URL=http://auth-service:8001
DOCUMENT_SERVICE_URL=http://document-service:8002
# RAG для document-service: в Docker Compose имя сервиса — rag-service (не localhost, не пустая строка).
RAG_SERVICE_URL=http://rag-service:8003
AI_SERVICE_URL=http://ai-service:8004

# document-service: разрешить загрузку без JWT (только dev)
ALLOW_ANONYMOUS_UPLOAD=true

# Redis
REDIS_URL=redis://redis:6379/0

# API Gateway
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000

# Rate limit (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=120

# Токены (опционально)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM (ai-service) — см. docs/MISTRAL_MODELS.md
# mistral_sdk — официальный Mistral Python SDK (La Plateforme).
# openai_http — любой OpenAI-совместимый POST /v1/chat/completions (хакатон, vLLM и т.д.).
LLM_MODE=mistral_sdk
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai
# Примеры: mistral-small-latest | mistral-medium-latest | mistral-large-latest (для openai_http — имя модели на вашем сервере)
MISTRAL_CHAT_MODEL=mistral-small-latest
AI_REQUEST_TIMEOUT_SECONDS=120

# STT (распознавание речи) — OpenAI-совместимый POST /v1/audio/transcriptions
# GET /v1/models на STT требует заголовок: Authorization: Bearer <ключ> (в Swagger без ключа будет 401).
# Пример хакатона и curl: docs/HACKAI_STT.md
# STT_BASE_URL=https://hackai.centrinvest.ru:6640
# STT_API_KEY=
# STT_MODEL=
# Список имён моделей через наш gateway (после задания STT_*): GET http://localhost:8000/api/v1/ai/stt-models

# Пример переключения на шлюз хакатона (OpenAI-совместимый, модель уточняйте через GET /api/v1/ai/models):
# LLM_MODE=openai_http
# MISTRAL_BASE_URL=https://hackai.centrinvest.ru:6630
# MISTRAL_API_KEY=<ключ из организаторов>
# MISTRAL_CHAT_MODEL=gpt-oss-20b
